# Podletters Celery worker image.
#
# Runs ingestion, LLM client, F5-TTS rendering, audio post-processing and
# MinIO upload tasks. Needs CUDA at runtime for F5-TTS, plus ffmpeg for
# pydub / loudness normalization.
#
# We start from the official PyTorch CUDA runtime image so torch is already
# matched against the CUDA toolkit. Dependencies are installed from
# pyproject.toml + uv.lock via uv; the `--inexact` flag preserves the
# pre-installed torch in /opt/conda instead of uninstalling it. F5-TTS
# comes in through the `tts` optional extra. Dev deps (pytest, ruff) are
# included so `make test` / `make lint` work via `docker compose exec`.

FROM pytorch/pytorch:2.3.0-cuda12.1-cudnn8-runtime

COPY --from=ghcr.io/astral-sh/uv:0.8.17 /uv /uvx /bin/

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    UV_PROJECT_ENVIRONMENT=/opt/conda \
    UV_LINK_MODE=copy \
    UV_COMPILE_BYTECODE=1 \
    UV_NO_CACHE=1

# System deps: ffmpeg for audio encoding/normalization, libsndfile for
# soundfile, build tooling for any wheels that need compilation.
RUN apt-get update && apt-get install -y --no-install-recommends \
        ffmpeg \
        libsndfile1 \
        build-essential \
        git \
        curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Install Python deps first for layer caching.
COPY pyproject.toml uv.lock ./
RUN uv sync --inexact --no-install-project --frozen \
        --extra tts --extra dev

# Source is bind-mounted from the host in development (see docker-compose.yml).
# For production builds, COPY src/ here instead.
ENV PYTHONPATH=/app/src

# Default command is overridden by docker-compose.
CMD ["celery", "-A", "podletters.celery_app", "worker", "--loglevel=INFO", "--concurrency=1", "-B"]
