# Email
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=you@gmail.com
IMAP_PASSWORD=your-app-password
IMAP_FOLDER=INBOX
SENDER_WHITELIST=tldrnewsletter@example.com,therundown.ai@example.com
POLL_INTERVAL_SECONDS=900

# LLM
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:32b-instruct-q4_K_M
OLLAMA_TIMEOUT_SECONDS=300

# TTS
F5TTS_REF_AUDIO_HOST1=refs/host1.wav
F5TTS_REF_TEXT_HOST1=Hallo und willkommen, schön dass du dabei bist.
F5TTS_REF_AUDIO_HOST2=refs/host2.wav
F5TTS_REF_TEXT_HOST2=Genau, das finde ich wirklich interessant.
SEGMENT_SILENCE_MS=400

# Audio
TARGET_LUFS=-16.0
MP3_BITRATE=128k
AUDIO_SAMPLE_RATE=22050

# Storage
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=podcast-episodes

# Celery / Redis
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Podcast metadata
PODCAST_TITLE=Mein Newsletter Podcast
PODCAST_AUTHOR=Eric
PODCAST_BASE_URL=http://localhost:9000
